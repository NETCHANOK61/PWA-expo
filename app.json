{
  "expo": {
    "name": "PWA Field Service",
    "slug": "pwa-field-service",
    "version": "1.0.45",
    "orientation": "portrait",
    "icon": "assets/os-icon/prd.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pwa.smart1662.ios",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take photos for service reporting.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to tag service locations.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/os-icon/prd.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pwa.smart1662.android",
      "versionCode": 63,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "assets/os-icon/prd.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "ed3ad2bb-0420-4e2a-81b2-671465323c93"
      }
    }
  }
}
