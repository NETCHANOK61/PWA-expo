{
  "expo": {
    "name": "PWA Field Service",
    "slug": "pwa-field-service",
    "version": "1.0.52",
    "orientation": "portrait",
    "icon": "assets/os-icon/prd.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pwa.smart1662.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "แอปนี้ต้องการใช้กล้องเพื่อถ่ายภาพประกอบงาน",
        "NSPhotoLibraryUsageDescription": "แอปนี้ต้องการเข้าถึงคลังภาพเพื่อเลือกรูปภาพ",
        "NSPhotoLibraryAddUsageDescription": "แอปนี้ต้องการบันทึกรูปลงในคลังภาพ",
        "NSLocationWhenInUseUsageDescription": "แอปนี้ใช้ตำแหน่งของคุณเพื่อระบุตำแหน่งหน้างาน",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/os-icon/prd.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pwa.smart1662.android",
      "versionCode": 77,
      "targetSdkVersion": 35,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "assets/os-icon/prd.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": false,
          "cameraPermission": "แอปนี้ต้องการใช้กล้องเพื่อถ่ายภาพประกอบงาน"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f01f2539-b4cc-43d1-9b50-7525c8c49ba7"
      }
    }
  }
}
